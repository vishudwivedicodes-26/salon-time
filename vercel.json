{
  "version": 2,
  "installCommand": "pnpm install --ignore-scripts",
  "builds": [
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/salon-booking/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "artifacts/api-server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "artifacts/salon-booking/$1"
    }
  ]
}
